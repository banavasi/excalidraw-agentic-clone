# Excaliboard self-host config. Copy to `.env` and fill in.  (never commit .env)

# --- required ---
# Postgres password for the bundled db service.
DB_PASSWORD=change-me
# Signs session cookies + email tokens. Generate: openssl rand -hex 32
SECRET_KEY=change-me

# --- recommended ---
# Public URL users hit (used in email links + decides the cookie Secure flag).
# Behind https put the https URL here; leave as-is for plain local testing.
PUBLIC_URL=http://localhost:8080
# Host port the editor is served on.
PORT=8080
# The email auto-granted admin on first sign-in.
ADMIN_EMAIL=you@example.com

# --- email (optional) ---
# Without SMTP_HOST, verification/reset links are printed to the api container
# log (`docker compose logs api`) so you can still bootstrap.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Excaliboard <no-reply@example.com>

# --- Google sign-in (optional) ---
# Create an OAuth client at https://console.cloud.google.com (Web application),
# authorized redirect URI: <PUBLIC_URL>/auth/google/callback. Leave blank to hide
# the Google button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
