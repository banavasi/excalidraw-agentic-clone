# Excaliboard sync service config.
# Copy to .env (mode 0600) and seed real values from 1Password Mithra at deploy.
# NEVER commit a real .env (it is .gitignore'd).

# Postgres password — op read "op://Mithra/excaliboard-db-cosmos/password"
DB_PASSWORD=__set_me__

# Static bearer — DEPRECATED (Phase 7). Still maps to the legacy single-user
# account so the existing MCP tool keeps working until per-user device tokens
# replace it. op read "op://Mithra/excaliboard-sync-auth/static_bearer"
SYNC_BEARER=__set_me__

# Comma-separated allowed browser origins (tighten from "*" at deploy).
CORS_ORIGINS=https://excalidraw.com

# --- Phase 7: multi-user in-app auth ----------------------------------------
# Signs session cookies + verify/reset email tokens. REQUIRED for auth.
#   op read "op://Mithra/excaliboard-secret-key/value"   (openssl rand -hex 32)
SECRET_KEY=__set_me__
# Public base URL (email links + cookie Secure flag decision).
PUBLIC_URL=https://app.shashankshandilya.me
# The email auto-granted admin + the identity the legacy SYNC_BEARER maps to.
ADMIN_EMAIL=shashank.v.shandilya@gmail.com

# SMTP for verification/reset email. If SMTP_HOST is empty, links are logged to
# stdout (read them from `docker logs` to bootstrap without a mail server).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Excaliboard <no-reply@shashankshandilya.me>

# Google OAuth (optional). Both empty => the Google button is hidden.
#   op read "op://Mithra/excaliboard-google-oauth/client_id" / client_secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Observability (fleet-obs → Phoenix on the cosmos tailnet).
PHOENIX_COLLECTOR_ENDPOINT=http://100.107.79.35:6006
# FLEET_OBS_DISABLE=1   # uncomment to disable tracing entirely

# Anti-DoS limits (defaults shown; raise/lower per host capacity).
# MAX_CIPHERTEXT_BYTES=26214400     # 25 MiB per scene/file payload
# MAX_BODY_BYTES=37748736           # 36 MiB whole-request cap (rejected pre-buffer)
# MAX_BOARDS_PER_USER=5000
# MAX_FILES_PER_BOARD=5000
# TOMBSTONE_GRACE_SECONDS=604800    # reap soft-deleted boards after 7 days (at startup)

# NOTE: DATABASE_URL is injected by docker-compose (points at the postgres
# service). The E2E encryption key (op://Mithra/excaliboard-e2e-key) lives only
# on the CLIENT — the server never sees it.
