# Excaliboard — self-host (web) build. PUBLIC config only; NO secrets.
# Build with:  yarn build:selfhost   (= vite build --mode selfhost)
#
# Loaded INSTEAD of .env.production, so the upstream excalidraw.com service URLs
# (json / collab / AI / libraries / plus / firebase) are simply absent → those
# features stay dormant for a single-user self-host.

MODE="selfhost"

# Self-host flag — EJS-gates the telemetry blocks in index.html OFF
# (SimpleAnalytics, the Excalidraw+ auto-redirect, the Google-fonts preconnect).
VITE_APP_SELFHOST=true

# No telemetry.
VITE_APP_DISABLE_SENTRY=true
VITE_APP_ENABLE_TRACKING=false

# Pre-fill the Cloud-sync server URL so the user only enters bearer + E2E key.
# NOT a secret. The bearer + E2E key are NEVER baked — they stay user-entered
# (browser localStorage `excaliboard:sync-config`).
VITE_APP_EXCALIBOARD_URL=https://excaliboard.shashankshandilya.me

# Keep firebase init a clean no-op if the lazy collab/shared-image path is ever hit.
VITE_APP_FIREBASE_CONFIG='{}'
